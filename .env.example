# Google Workspace MCP — Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env

# ── Required ─────────────────────────────────────────────────────────────────
# Create these at: https://console.cloud.google.com/apis/credentials
# Select "OAuth Client ID" → "Desktop Application"
GOOGLE_OAUTH_CLIENT_ID="your-google-client-id"
GOOGLE_OAUTH_CLIENT_SECRET="your-google-client-secret"

# ── Optional ─────────────────────────────────────────────────────────────────
# Default user email (single-user mode — skips email prompt)
# USER_GOOGLE_EMAIL="you@example.com"

# Allow HTTP OAuth redirects (required for localhost development)
# OAUTHLIB_INSECURE_TRANSPORT=1

# Custom credentials storage (default: ~/.google_workspace_mcp/credentials/)
# WORKSPACE_MCP_CREDENTIALS_DIR="/path/to/credentials"

# Server port (default: 8000)
# WORKSPACE_MCP_PORT=8000

# Custom Search (only needed for gsearch tools)
# GOOGLE_PSE_API_KEY="your-pse-api-key"
# GOOGLE_PSE_ENGINE_ID="your-pse-engine-id"

# ── Advanced (OAuth 2.1 / multi-user / production) ──────────────────────────
# See .env.oauth21 for full OAuth 2.1 configuration including:
# - Storage backends (memory, disk, Valkey/Redis)
# - External OAuth providers
# - Stateless container mode
# - Reverse proxy settings
